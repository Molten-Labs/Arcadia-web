# ── Backend (Railway) ─────────────────────────────────────────────────────────
# Set this to your Railway deployment URL once the server is live.
# Without it, the frontend uses mock data.
BACKEND_URL=https://your-server.up.railway.app

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Public-facing RPC used by the browser wallet (Phantom, Solflare).
# Get a free key at https://helius.dev — or leave blank for public devnet.
NEXT_PUBLIC_HELIUS_RPC=https://api.devnet.solana.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Must match JWT_SECRET in the Railway backend so tokens are accepted.
JWT_SECRET=change-me-in-production

# ── Program ──────────────────────────────────────────────────────────────────
# Solana program ID — only override if you redeploy to a different address.
NEXT_PUBLIC_PROGRAM_ID=gTHauBMdJHs45tc8tjCKL7MejvBECQHgD184io3hx1C
